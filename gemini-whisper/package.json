{
  "name": "gemini-whisper",
  "private": true,
  "version": "0.0.0",
  "author": "Gemini User",
  "description": "Gemini Whisper Application",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && set ELECTRON_RUN_AS_NODE= && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.2.4",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^34.1.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.12",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.gemini.whisper",
    "productName": "Gemini Whisper",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "forceCodeSigning": false,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
