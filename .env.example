# --- Gemini (transcrição + ata) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- IMAP (ler e-mails com anexo de áudio) ---
IMAP_HOST=imap.gmail.com
IMAP_SSL=true
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# --- SMTP (enviar ata) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=

# Gatilho: o assunto deve conter este texto (ex.: [TRANSCRICAO])
EMAIL_SUBJECT_TRIGGER=[TRANSCRICAO]

# Remetente visível e lista de destinatários (separados por vírgula)
ATA_FROM_EMAIL=
ATA_REPLY_TO=
ATA_RECIPIENTS=

# Opcional: ficheiro .md de template (ex.: pasta "Template de atas")
# ATA_TEMPLATE_PATH=Template de atas/08-ATA-CONTATO-CLIENTE-TEMPLATE-R00.md

# Incluir transcrição bruta no e-mail (default: não)
INCLUDE_RAW_TRANSCRIPT_IN_EMAIL=false

# --- Next.js / Neon (web/) ---
DATABASE_URL=
