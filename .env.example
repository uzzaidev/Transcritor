# ----------------------------
# Canonical root env (shared)
# ----------------------------

# --- Gemini (transcricao + ATA no ata_agent e gemini-whisper) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI (ata_multiagent_pipeline) ---
OPENAI_API_KEY=
PIPELINE_OPENAI_MODEL=gpt-4o-mini

# --- IMAP (leitura de e-mails com audio) ---
IMAP_HOST=imap.gmail.com
IMAP_SSL=true
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# Subject trigger (ex.: [TRANSCRICAO])
EMAIL_SUBJECT_TRIGGER=[TRANSCRICAO]

# --- SMTP (envio de ATA) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USE_TLS=1
SMTP_USER=
SMTP_USERNAME=
SMTP_PASSWORD=

# Sender / recipients
ATA_FROM_EMAIL=
SMTP_FROM_EMAIL=
ATA_REPLY_TO=
ATA_RECIPIENTS=
SMTP_FROM_NAME=ATA Pipeline
SMTP_DRY_RUN=0

# Optional template path for ata_agent
# ATA_TEMPLATE_PATH=Template de atas/08-ATA-CONTATO-CLIENTE-TEMPLATE-R00.md

# Include raw transcript in ata_agent email body
INCLUDE_RAW_TRANSCRIPT_IN_EMAIL=false

# Retry controls for ata_agent reliability
SMTP_RETRY_ATTEMPTS=3
SMTP_RETRY_BASE_SECONDS=1
SMTP_RETRY_MAX_SECONDS=30
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_BASE_SECONDS=1
GEMINI_RETRY_MAX_SECONDS=30

# ata_agent local stores
# ATA_PROCESSED_STORE=.cache/ata_agent/processed.json
# ATA_TEMP_DIR=.cache/ata_agent/tmp

# --- Optional advanced pipeline flags (keep disabled by default) ---
PIPELINE_GIT_ENABLED=0
PIPELINE_GIT_ALLOW_PUSH=0
PIPELINE_DESTRUCTIVE_GIT_OPS=0
PIPELINE_SCRIPTOPS_ENABLED=0
PIPELINE_GIT_REMOTE=origin
PIPELINE_GIT_BRANCH=main
PIPELINE_MIN_VALIDATION_SCORE=80

# --- Next.js / Neon (web/) ---
DATABASE_URL=
DASHBOARD_BASIC_AUTH_USER=
DASHBOARD_BASIC_AUTH_PASSWORD=
